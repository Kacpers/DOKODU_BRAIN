# Python
scripts/__pycache__/
scripts/*.pyc
*.pyc
*.pyo

# Lokalne bazy SQLite (regenerowane przez skrypty)
*.db
*.db-shm
*.db-wal

# Tokeny i credentials (trzymane w ~/.config/dokodu/)
*.pickle
*.json
*.key

# Wyjątki dla tender-doc-filler (pliki JSON są częścią kodu)
!tender-doc-filler/**/*.json

# Logi
*.log
/tmp/

# System
.DS_Store
Thumbs.db

# Edytory
.vscode/
.idea/
*.swp

# Node.js
node_modules/
npm-debug.log

# Pliki tymczasowe
*.tmp
*.bak

# Sync daemon state (regenerowane przez sync daemon)
.sync_state.json
.sync_mapping.json
